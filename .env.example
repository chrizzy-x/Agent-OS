# Supabase - PostgreSQL database and file storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Redis Cloud - key-value cache and pub/sub
REDIS_URL=redis://default:password@hostname:port

# Security - generate with: openssl rand -hex 32
JWT_SECRET=your-256-bit-secret-here
ENCRYPTION_KEY=your-256-bit-encryption-key-here

# Agent limits
MAX_AGENTS=1000
STORAGE_QUOTA_GB=1
MEMORY_QUOTA_MB=100
RATE_LIMIT_PER_MIN=100

# Network primitive - comma-separated allowed outbound domains (leave empty to block all)
ALLOWED_DOMAINS=

# Admin authentication token for creating agents
ADMIN_TOKEN=your-admin-token-here

# ── FFP Integration (optional) ───────────────────────────────────────────────
# Set FFP_MODE=enabled to activate Furge Fabric Protocol routing.
# When disabled (default), all FFP code is dormant — zero overhead.
FFP_MODE=disabled

# Which FFP chain to log operations to (e.g. "health-chain", "finance-chain")
FFP_CHAIN_ID=

# FFP network node endpoint
FFP_NODE_URL=

# Cryptographic identity for this AgentOS instance on the FFP network
FFP_AGENT_ID=

# Enforce FFP consensus before executing critical outbound calls (default: false)
FFP_REQUIRE_CONSENSUS=false

# ─────────────────────────────────────────────────────────────────────────────
# Node environment
NODE_ENV=development
