# Core app URLs
NEXT_PUBLIC_APP_URL=https://agentos-app.vercel.app
NEXT_PUBLIC_API_URL=https://agentos-app.vercel.app

# Supabase
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Legacy alias - SUPABASE_SERVICE_KEY is accepted as a fallback
# SUPABASE_SERVICE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://default:password@hostname:port

# Security
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_TOKEN=replace-with-an-admin-token
CRON_SECRET=replace-with-a-cron-secret

# Agent defaults
MAX_AGENTS=1000
STORAGE_QUOTA_GB=1
MEMORY_QUOTA_MB=100
RATE_LIMIT_PER_MIN=100
ALLOWED_DOMAINS=

# MCP and consensus
FFP_MODE=enabled
FFP_CHAIN_ID=your-chain-id
FFP_NODE_URL=https://your-ffp-node.example.com
FFP_AGENT_ID=your-agent-id
FFP_REQUIRE_CONSENSUS=false
MCP_CONSENSUS_WAIT_MS=3000
MCP_CONSENSUS_DEFAULT_THRESHOLD=0.67

# Optional AI assistance
ANTHROPIC_API_KEY=your-anthropic-api-key

# Runtime
NODE_ENV=development

# Shared social secret management
SOCIAL_TOKEN_ENCRYPTION_KEY=replace-with-64-char-hex-or-32-byte-base64-key
# Legacy fallback for older X-only installs
X_TOKEN_ENCRYPTION_KEY=replace-with-64-char-hex-or-32-byte-base64-key

# X integration
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=https://agentos-app.vercel.app/api/x/callback
X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access

# Meta integration (Facebook, Instagram, and WhatsApp)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://agentos-app.vercel.app/api/meta/callback

# Telegram integration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Google / YouTube integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://agentos-app.vercel.app/api/youtube/callback
