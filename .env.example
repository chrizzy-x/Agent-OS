# Core app URLs
NEXT_PUBLIC_APP_URL=https://agent-os-one-eta.vercel.app
NEXT_PUBLIC_API_URL=https://agent-os-one-eta.vercel.app

# Supabase
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Legacy alias — SUPABASE_SERVICE_KEY is accepted as a fallback
# SUPABASE_SERVICE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://default:password@hostname:port

# Security
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_TOKEN=replace-with-an-admin-token
CRON_SECRET=replace-with-a-cron-secret

# Agent defaults
MAX_AGENTS=1000
STORAGE_QUOTA_GB=1
MEMORY_QUOTA_MB=100
RATE_LIMIT_PER_MIN=100
ALLOWED_DOMAINS=

# MCP and consensus
FFP_MODE=enabled
FFP_CHAIN_ID=your-chain-id
FFP_NODE_URL=https://your-ffp-node.example.com
FFP_AGENT_ID=your-agent-id
FFP_REQUIRE_CONSENSUS=false
MCP_CONSENSUS_WAIT_MS=3000
MCP_CONSENSUS_DEFAULT_THRESHOLD=0.67

# Optional AI assistance
ANTHROPIC_API_KEY=your-anthropic-api-key

# Runtime
NODE_ENV=development
