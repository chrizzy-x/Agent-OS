    "description": "AgentOS - the operating system for the agent economy: chat, route, install, publish, and operate agents, apps, skills, workflows, and MCP tools",
    "author": "riz",
    "homepage": "https://www.agentos.services",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
