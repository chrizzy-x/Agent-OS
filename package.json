        "jsonwebtoken": "^9.0.2",
        "next": "^15.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitest/coverage-v8": "^1.0.4",
        "autoprefixer": "^10.4.20",
